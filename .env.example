# =============================================================================
# API KEYS — copy this file to ".env" and fill in your free keys.
#   cp .env.example .env
# The .env file is loaded automatically by python-dotenv. NEVER commit .env.
# =============================================================================

# FRED (Federal Reserve Economic Data) — free, instant.
# Get a key here:  https://fredapi.stlouisfed.org/  ->  "Request API Key"
# Used for: CPI inflation, real 10Y yield (TIPS), M2 money supply.
FRED_API_KEY=your_fred_api_key_here

# NewsAPI — free developer tier (limited requests/day).
# Get a key here:  https://newsapi.org/register
# OPTIONAL: if missing or quota-exceeded, the system falls back to RSS feeds.
NEWSAPI_KEY=your_newsapi_key_here
